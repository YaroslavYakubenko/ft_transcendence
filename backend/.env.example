# Django core settings
SECRET_KEY=your-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,transcendence_backend

# OAuth credentials (localhost)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth credentials (IP / remote access — second OAuth app)
GITHUB_CLIENT_ID_IP=your-github-client-id-for-ip
GITHUB_CLIENT_SECRET_IP=your-github-client-secret-for-ip

FORTY_TWO_CLIENT_ID=your-42-client-id
FORTY_TWO_CLIENT_SECRET=your-42-client-secret
FORTY_TWO_CLIENT_ID_IP=your-42-client-id-for-ip
FORTY_TWO_CLIENT_SECRET_IP=your-42-client-secret-for-ip

# Database configuration (must match docker-compose)
DB_NAME=transcendence_db
DB_USER=transcendence_user
DB_PASSWORD=transcendence_password

# Important: use service name "db" in Docker
DB_HOST=db
DB_PORT=5432
