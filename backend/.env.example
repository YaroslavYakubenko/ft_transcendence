# Django core settings
SECRET_KEY=your-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,transcendence_backend

# OAuth credentials
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
FORTY_TWO_CLIENT_ID=your-42-client-id
FORTY_TWO_CLIENT_SECRET=your-42-client-secret

# Database configuration (must match docker-compose)
# Set USE_SQLITE=True only if you intentionally want a local file database.
# Otherwise Postgres is used and persisted via the postgres_data volume.
DB_NAME=transcendence_db
DB_USER=transcendence_user
DB_PASSWORD=transcendence_password

# Important: use service name "db" in Docker
DB_HOST=db
DB_PORT=5432
